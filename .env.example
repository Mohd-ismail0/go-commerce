# Copy to .env and override per environment. For production, set APP_ENV=production and use strong secrets + TLS on DATABASE_URL.
APP_ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rewrite?sslmode=disable
API_AUTH_TOKEN=change-me
AUTH_JWT_SECRET=change-me-jwt-secret
AUTH_JWT_KEYSET=
AUTH_JWT_TTL_MINUTES=60
AUTH_REFRESH_TTL_MINUTES=10080
ALLOW_LEGACY_ROLE_BYPASS=false
DEFAULT_REGION_ID=global
DEFAULT_TENANT_ID=public
WEBHOOK_TIMEOUT_MS=3000
WEBHOOK_PAYMENT_SECRET=
PAYMENT_RECONCILE_INTERVAL_SECONDS=300
HTTP_TIMEOUT_MS=10000
HTTP_MAX_BODY_BYTES=1048576
LOG_LEVEL=info
